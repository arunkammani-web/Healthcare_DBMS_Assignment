create database healthcare;

use healthcare;



###PATIENT

CREATE TABLE Patient (
Patient_ID VARCHAR(10) PRIMARY KEY,
Full_Name  VARCHAR(100) NOT NULL UNIQUE,
Date_of_Birth DATE  NOT NULL,
Gender VARCHAR(20),
Contact_Number VARCHAR(15) NOT NULL
);

describe table Patient;

select * from Patient;

###DOCTOR

CREATE TABLE Doctor (
Doctor_ID  VARCHAR(10) PRIMARY KEY,
Name VARCHAR(100) NOT NULL,
Specialisation  VARCHAR(50)  NOT NULL,
Phone_Number VARCHAR(15),
Email_Address VARCHAR(100)
);

describe table Doctor;

select * from Doctor;


###FACILITY

CREATE TABLE Facility (
Facility_Code VARCHAR(10) PRIMARY KEY,
Name VARCHAR(100) NOT NULL,
Address VARCHAR(200) NOT NULL,
Contact_Number VARCHAR(15)  NOT NULL
);

select * from Facility;

 ###TREATMENT
 
CREATE TABLE Treatment (
Treatment_ID VARCHAR(10) PRIMARY KEY,
Name VARCHAR(100) NOT NULL,
Description VARCHAR(50),  
Cost DECIMAL(8,2) NOT NULL
);

select * from Treatment;

###APPOINTMENT


CREATE TABLE Appointment (
Appointment_ID VARCHAR(10) PRIMARY KEY,
Appointment_Date DATE NOT NULL,
Appointment_Time TIME  NOT NULL,
Patient_ID VARCHAR(10) NOT NULL,
Doctor_ID VARCHAR(10) NOT NULL,
Facility_Code  VARCHAR(10) NOT NULL,
FOREIGN KEY (Patient_ID)  REFERENCES Patient(Patient_ID),
FOREIGN KEY (Doctor_ID)  REFERENCES Doctor(Doctor_ID),
FOREIGN KEY (Facility_Code) REFERENCES Facility(Facility_Code)
);

select * from Appointment;

###PATIENT_DOCTOR_TREATMENT 

CREATE TABLE Patient_Doctor_Treatment (
Patient_ID VARCHAR(10),
Doctor_ID  VARCHAR(10),
Treatment_ID VARCHAR(10),
Treatment_Date  DATE NOT NULL,
PRIMARY KEY (Patient_ID, Doctor_ID, Treatment_ID, Treatment_Date),
FOREIGN KEY (Patient_ID) REFERENCES Patient(Patient_ID),
FOREIGN KEY (Doctor_ID)  REFERENCES Doctor(Doctor_ID),
FOREIGN KEY (Treatment_ID) REFERENCES Treatment(Treatment_ID)
);

select * from Patient_Doctor_Treatment;

###APPOINTMENT_TREATMENT 

CREATE TABLE Appointment_Treatment (
Appointment_ID  VARCHAR(10),
Treatment_ID  VARCHAR(10),
PRIMARY KEY (Appointment_ID, Treatment_ID),
FOREIGN KEY (Appointment_ID) REFERENCES Appointment(Appointment_ID),
FOREIGN KEY (Treatment_ID) REFERENCES Treatment(Treatment_ID)
);

select * from Appointment_Treatment;

