###PART 3 Business Questions

###a) List all appointments for patient 'Alice Green'


SELECT a.*
FROM Appointment a
JOIN Patient p ON a.Patient_ID = p.Patient_ID
WHERE p.Full_Name = 'Alice Green';

###b) Total number of treatments administered by each doctor

SELECT d.Doctor_ID,
COUNT(*) AS Total_Treatments
FROM Appointment a
JOIN Appointment_Treatment at ON a.Appointment_ID = at.Appointment_ID
JOIN Doctor d ON a.Doctor_ID = d.Doctor_ID
GROUP BY d.Doctor_ID;

###c) Doctors who have treated more than 5 patients

SELECT d.Doctor_ID,
COUNT(DISTINCT a.Patient_ID) AS Patient_Count
FROM Appointment a
JOIN Doctor d ON a.Doctor_ID = d.Doctor_ID
GROUP BY d.Doctor_ID
HAVING COUNT(DISTINCT a.Patient_ID) > 5;

###d) Facilities where patient 'Mark Lee' has received treatment

SELECT DISTINCT f.*
FROM Appointment a
JOIN Patient p ON a.Patient_ID = p.Patient_ID
JOIN Facility f ON a.Facility_Code = f.Facility_Code
WHERE p.Full_Name = 'Mark Lee';

### e: Patients with their doctors and treatment names

SELECT p.Full_Name,
d.Name,
t.Name
FROM Appointment a
JOIN Patient p ON a.Patient_ID = p.Patient_ID
JOIN Doctor d ON a.Doctor_ID = d.Doctor_ID
JOIN Appointment_Treatment at ON a.Appointment_ID = at.Appointment_ID
JOIN Treatment t ON at.Treatment_ID = t.Treatment_ID;

###f) Most expensive treatment and the doctor who administered it

SELECT t.Name,t.Cost,d.Name
FROM Treatment t
JOIN Appointment_Treatment at ON t.Treatment_ID = at.Treatment_ID
JOIN Appointment a ON at.Appointment_ID = a.Appointment_ID
JOIN Doctor d ON a.Doctor_ID = d.Doctor_ID
WHERE t.Cost = (SELECT MAX(Cost) FROM Treatment);

###g) Patients with appointments in more than one facility

SELECT p.Full_Name,
COUNT(DISTINCT a.Facility_Code) AS Facility_Count
FROM Appointment a
JOIN Patient p ON a.Patient_ID = p.Patient_ID
GROUP BY p.Patient_ID, p.Full_Name
HAVING COUNT(DISTINCT a.Facility_Code) > 1;

