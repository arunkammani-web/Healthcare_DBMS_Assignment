### 8: Treatments by facility with simple CASE and GROUP BY

SELECT f.Name,
COUNT(at.Treatment_ID) AS Total_Treatments,
AVG(t.Cost)AS Average_Treatment_Cost,
CASE
WHEN COUNT(at.Treatment_ID) > 10 THEN 'High Activity'
ELSE 'Low Activity'
END AS Activity_Level
FROM Facility f
JOIN Appointment a ON f.Facility_Code = a.Facility_Code
JOIN Appointment_Treatment at ON a.Appointment_ID = at.Appointment_ID
JOIN Treatment t ON at.Treatment_ID = t.Treatment_ID
GROUP BY f.Facility_Code, f.Name;










